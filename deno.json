{
    "imports": {
        "esbuild": "npm:esbuild@^0.25.5",
		"@escape-js": "https://cdn.jsdelivr.net/gh/mesgjs/escape-js@0.0.4/src/escape.esm.js",
		"mesgjs/": "./",
		"@nanos": "https://cdn.jsdelivr.net/gh/mesgjs/nanos@1.3.0/src/nanos.esm.js",
		"@reactive": "https://cdn.jsdelivr.net/gh/mesgjs/reactive@0.1.6/src/reactive.esm.js"
    },
    "tasks": {
		"runtime-min": "deno run --allow-run --allow-read --allow-write --allow-env npm:esbuild src/runtime/*.js --minify --outdir=dist/runtime-min --format=esm --sourcemap=external"
    }
}
